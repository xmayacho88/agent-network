@app.get("/api/orders/latest")
async def get_latest_orders(min_price: int = 0, limit: int = 20):
    """Последние заказы"""
    DATABASE_URL = os.environ.get("DATABASE_URL")
    if not DATABASE_URL:
        # Демо-заказы если нет БД
        demo_orders = [
            {"platform": "Kwork", "title": "Создание сайта на Python", "price": 15000, "link": "https://kwork.ru/projects/1"},
            {"platform": "Freelancehunt", "title": "Дизайн логотипа", "price": 5000, "link": "https://freelancehunt.com/project/1"},
            {"platform": "Habr", "title": "Парсинг Wildberries", "price": 10000, "link": "https://freelance.habr.com/tasks/1"}
        ]
        return {"orders": demo_orders}
    
    conn = await asyncpg.connect(DATABASE_URL)
    rows = await conn.fetch(
        "SELECT platform, title, price, link, found_at FROM orders WHERE price >= $1 ORDER BY found_at DESC LIMIT $2",
        min_price, limit
    )
    await conn.close()
    
    return {"orders": [dict(row) for row in rows]}

@app.post("/api/orders/add")
async def add_order(order: OrderRequest):
    """Добавить заказ (для парсера)"""
    DATABASE_URL = os.environ.get("DATABASE_URL")
    if not DATABASE_URL:
        return {"status": "no_db"}
    
    conn = await asyncpg.connect(DATABASE_URL)
    await conn.execute(
        "INSERT INTO orders (platform, title, price, link, skills, found_at) VALUES ($1, $2, $3, $4, $5, NOW())",
        order.platform, order.title, order.price, order.link, order.skills
    )
    await conn.close()
    
    return {"status": "added"}

