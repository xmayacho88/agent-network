@app.post("/api/agent/run")
async def run_agent(request: TaskRequest):
    """Запуск агента"""
    DEEPSEEK_KEY = os.environ.get("DEEPSEEK_KEY")
    
    # Системные промпты для агентов
    prompts = {
        "Фриланс-агент": "Ты профессиональный фрилансер. Ищешь заказы на Kwork, Freelancehunt, Habr. Давай конкретные ссылки, цены, советы по отклику.",
        "Кодер": "Ты опытный разработчик. Пиши качественный код с комментариями, объясняй решения, давай готовые примеры.",
        "Аналитик": "Ты бизнес-аналитик. Анализируй рынок, тренды, конкурентов. Давай цифры и факты.",
        "Дизайнер": "Ты креативный дизайнер. Генерируй идеи для логотипов, карточек товаров, инфографики.",
        "Стратег": "Ты бизнес-стратег. Создавай пошаговые планы, прогнозы, стратегии развития."
    }
    
    system_prompt = prompts.get(request.agent_name, "Ты полезный помощник")
    
    # Сохраняем задачу в БД
    DATABASE_URL = os.environ.get("DATABASE_URL")
    if DATABASE_URL:
        conn = await asyncpg.connect(DATABASE_URL)
        await conn.execute(
            "INSERT INTO tasks (agent_name, task_text, status) VALUES ($1, $2, 'processing')",
            request.agent_name, request.task
        )
        await conn.close()
    
    # Вызов DeepSeek
    try:
        async with httpx.AsyncClient(timeout=60.0) as client:
            response = await client.post(
                "https://api.deepseek.com/v1/chat/completions",
                headers={
                    "Authorization": f"Bearer {DEEPSEEK_KEY}",
                    "Content-Type": "application/json"
                },
                json={
                    "model": "deepseek-chat",
                    "messages": [
                        {"role": "system", "content": system_prompt},
                        {"role": "user", "content": request.task}
                    ],
                    "temperature": 0.7,
                    "max_tokens": 1500
                }
            )
            data = response.json()
            
            if "error" in data:
                result = f"❌ Ошибка API: {data['error'].get('message', 'Неизвестная ошибка')}"
            else:
                result = data["choices"][0]["message"]["content"]
    
    except Exception as e:
        result = f"❌ Ошибка: {str(e)}"
    
    # Обновляем результат в БД
    if DATABASE_URL:
        conn = await asyncpg.connect(DATABASE_URL)
        await conn.execute(
            "UPDATE tasks SET status = 'completed', result = $1 WHERE id = (SELECT MAX(id) FROM tasks)",
            result
        )
        await conn.close()
    
    return {"status": "success", "result": result}

@app.get("/api/agents/history")
async def get_history(limit: int = 20):
    """История работы агентов"""
    DATABASE_URL = os.environ.get("DATABASE_URL")
    if not DATABASE_URL:
        return {"history": []}
    
    conn = await asyncpg.connect(DATABASE_URL)
    rows = await conn.fetch(
        "SELECT agent_name, task_text, status, result, created_at FROM tasks ORDER BY created_at DESC LIMIT $1",
        limit
    )
    await conn.close()
    
    return {"history": [dict(row) for row in rows]}

